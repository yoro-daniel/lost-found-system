APP_NAME="Lost and Found Management System"
APP_URL=http://localhost/Lost%20and%20Found/public

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lost_found_management
DB_USER=root
DB_PASS=
# Optional hosted MySQL URL. If set, this overrides DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASS.
# DATABASE_URL=mysql://username:password@hostname:3306/database_name
# For providers like Aiven that require SSL, set either:
# DB_SSL_CA_PATH=/absolute/path/to/ca.pem
# or DB_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15551234567
# Optional if you use a Messaging Service instead of a From number:
TWILIO_MESSAGING_SERVICE_SID=
# Fallback phone for seeded/demo users without a saved phone number. Use E.164 format, e.g. +639171234567.
OTP_FALLBACK_PHONE=
TWILIO_TIMEOUT=12

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=school-lost-found/items
